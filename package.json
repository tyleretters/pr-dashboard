{
  "name": "@northern-information/pr-dashboard",
  "version": "0.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Live terminal dashboard for GitHub PRs — fresher than the web UI, two-tier polling, scoped by org",
  "type": "module",
  "bin": {
    "prd": "bin/prd"
  },
  "files": [
    "bin",
    "src",
    "tsconfig.json",
    "README.md"
  ],
  "keywords": [
    "github",
    "pull-requests",
    "prs",
    "dashboard",
    "tui",
    "ink",
    "cli",
    "gh"
  ],
  "homepage": "https://github.com/northern-information/pr-dashboard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/northern-information/pr-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/northern-information/pr-dashboard/issues"
  },
  "license": "MIT",
  "author": "Tyler Etters",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.tsx",
    "start": "tsx src/main.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "ink": "5.2.1",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "18.3.1",
    "tsx": "4.21.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "24.12.0",
    "@types/react": "18.3.12",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "3.2.4"
  }
}
