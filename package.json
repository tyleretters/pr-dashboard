{
  "name": "pr-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Live terminal dashboard for GitHub PRs across orgs",
  "type": "module",
  "bin": {
    "prd": "bin/prd"
  },
  "scripts": {
    "dev": "tsx src/main.tsx",
    "start": "tsx src/main.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "engines": {
    "node": "24.13.0"
  },
  "dependencies": {
    "ink": "5.2.1",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "24.12.0",
    "@types/react": "18.3.12",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "3.2.4"
  }
}
